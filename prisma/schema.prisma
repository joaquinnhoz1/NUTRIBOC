generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Booking {
  id             String   @id @default(cuid())
  name           String
  email          String
  phone          String
  mode           String
  date           String
  slot           String
  paymentType    String
  status         String   @default("pending")
  mpPaymentId    String?
  mpPreferenceId String?
  amount         Float?
  notes          String?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BlockedSlot {
  id        String   @id @default(cuid())
  date      String
  slot      String
  mode      String
  reason    String?
  createdAt DateTime @default(now())
}

model BlockedDay {
  id        String   @id @default(cuid())
  date      String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
